@page "{id:int}"
@model EventManager.Pages.Account.Users.EditModel
@{
}

<div class="container mt-4">

    <h2>Редактировать пользователя</h2>

    <form method="post" enctype="multipart/form-data">

        <input type="hidden" asp-for="User.Id" />

        <div class="mb-3">
            <label class="form-label">Аватар</label>
            <input type="file" name="AvatarFile" class="form-control" />
        </div>

        @if (Model.User.Avatar != null && Model.User.Avatar.Length > 0)
        {
            <div class="mb-3">
                <img style="max-width:150px; border-radius: 10px;"
                     src="data:image/jpeg;base64,@Convert.ToBase64String(Model.User.Avatar)" />
            </div>
        }

        <div class="mb-3">
            <label asp-for="User.Email" class="form-label">Email</label>
            <input asp-for="User.Email" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="User.Password" class="form-label">Пароль</label>
            <input asp-for="User.Password" type="password" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="User.Role" class="form-label">Роль</label>
            <select asp-for="User.Role" class="form-control">
                <option value="User">User</option>
                <option value="Admin">Admin</option>
            </select>
        </div>

        <button type="submit" class="btn btn-warning">
            Сохранить
        </button>

        <a asp-page="Index" class="btn btn-secondary">
            Назад
        </a>

    </form>

</div>