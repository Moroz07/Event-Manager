@page
@model EventManager.Pages.Account.Users.IndexModel
@{
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Пользователи</h2>
        <a asp-page="Create" class="btn btn-primary">Создать пользователя</a>
    </div>

    <div class="row g-4">
        @foreach (var user in Model.Users)
        {
            <div class="col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        @if (user.Avatar != null && user.Avatar.Length > 0)
                        {
                            <img src="data:image/jpeg;base64,@Convert.ToBase64String(user.Avatar)"
                                 style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover;" />
                        }
                        else
                        {
                            <div style="width: 80px; height: 80px; border-radius: 50%; background-color: #6c757d; margin: 0 auto; line-height: 80px; color: white; font-size: 32px;">
                                👤
                            </div>
                        }
                        <h5 class="mt-2">@user.Name</h5>
                        <p class="text-muted">@user.Email</p>
                        <span class="badge bg-secondary">@user.Role</span>
                    </div>
                    <div class="card-footer bg-white border-0">
                        <div class="d-flex justify-content-between">
                            <a asp-page="Details" asp-route-id="@user.Id" class="btn btn-sm btn-info">Подробно</a>
                            <a asp-page="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning">Изменить</a>
                            <a asp-page="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger">Удалить</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>