@page
@model EventManager.Pages.Account.Users.DetailsModel
@{
}

<div class="container mt-4">

    <h2>Информация о пользователе</h2>

    <div class="card">

        <div class="card-body">

            <p><b>Email:</b> @Model.User.Email</p>
            <p><b>Роль:</b> @Model.User.Role</p>

        </div>

    </div>

    <br>

    <a asp-page="Edit" asp-route-id="@Model.User.Id"
       class="btn btn-warning">
        Редактировать
    </a>

    <a asp-page="Index" class="btn btn-secondary">
        Назад
    </a>

</div>