@page "{id:int}"
@model EventManager.Pages.Account.Users.DetailsModel
@{
}

<div class="container mt-4">
    <h2>Информация о пользователе</h2>

    <div class="card">
        <div class="card-body text-center">
            @if (Model.User.Avatar != null && Model.User.Avatar.Length > 0)
            {
                <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.User.Avatar)"
                     style="width: 150px; height: 150px; border-radius: 50%; object-fit: cover;" />
            }
            else
            {
                <div style="width: 150px; height: 150px; border-radius: 50%; background-color: #6c757d; margin: 0 auto; line-height: 150px; color: white; font-size: 64px;">
                    👤
                </div>
            }

            <h3 class="mt-3">@Model.User.Name</h3>
            <p><b>Email:</b> @Model.User.Email</p>
            <p><b>Роль:</b> <span class="badge bg-secondary">@Model.User.Role</span></p>
        </div>
    </div>

    <br>
    <a asp-page="Edit" asp-route-id="@Model.User.Id" class="btn btn-warning">Редактировать</a>
    <a asp-page="Index" class="btn btn-secondary">Назад</a>
</div>