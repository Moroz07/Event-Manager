@page
@model EventManager.Pages.EventParticipants.CreateModel
@{
}

<h1>Добавить участника</h1>

<form method="post">
    <div>
        <label>Имя</label><br />
        <input asp-for="Participant.Name" />
        <span asp-validation-for="Participant.Name"></span>
    </div>

    <div>
        <label>Фамилия</label><br />
        <input asp-for="Participant.LastName" />
        <span asp-validation-for="Participant.LastName"></span>
    </div>

    <div>
        <label>Email</label><br />
        <input asp-for="Participant.Email" type="email" />
    </div>

    <div>
        <label>Телефон</label><br />
        <input asp-for="Participant.Phone" />
    </div>

    <div>
        <label>ID мероприятия</label><br />
        <input asp-for="Participant.EventId" type="number" />
    </div>

    <button type="submit">Сохранить</button>
</form>

<a asp-page="Index">Назад</a>