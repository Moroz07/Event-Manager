@page "{id:int}"
@model EventManager.Pages.Participants.DetailsModel
@{
    ViewData["Title"] = "Информация об участнике";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Информация об участнике</h4>
                </div>
                <div class="card-body">

                    <h5 class="card-title mb-3">
                        👤 @Model.Participant.Name @Model.Participant.LastName
                    </h5>

                    <ul class="list-group list-group-flush mb-3">
                        <li class="list-group-item">
                            <strong>Email:</strong> @Model.Participant.Email
                        </li>
                        <li class="list-group-item">
                            <strong>Телефон:</strong> @Model.Participant.Phone
                        </li>
                        <li class="list-group-item">
                            <strong>ID мероприятия:</strong>
                            <span class="badge bg-secondary">@Model.Participant.EventId</span>
                        </li>
                    </ul>

                    <div class="d-flex justify-content-between">
                        <a asp-page="Index" class="btn btn-secondary">
                            Назад к списку
                        </a>
                        <a asp-page="Edit" asp-route-id="@Model.Participant.Id" class="btn btn-warning">
                            Редактировать
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>