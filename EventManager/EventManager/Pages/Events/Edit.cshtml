@page "{id:int}"
@model EventManager.Pages.Events.EditModel
@{
    ViewData["Title"] = "Редактировать мероприятие";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Редактировать мероприятие</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" asp-for="Event.Id" />
                        <div class="mb-3">
                            <label asp-for="Event.Name" class="form-label">Название мероприятия</label>
                            <input asp-for="Event.Name" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Event.EventDate" class="form-label">Дата проведения</label>
                            <input asp-for="Event.EventDate" type="date" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Event.location" class="form-label">Место проведения</label>
                            <input asp-for="Event.location" class="form-control" />
                        </div>
                        <div class="d-flex justify-content-between">
                            <a asp-page="Index" class="btn btn-secondary">Назад к списку</a>
                            <button type="submit" class="btn btn-warning">Сохранить изменения</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}