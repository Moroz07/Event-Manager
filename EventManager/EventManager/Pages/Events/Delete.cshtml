@page "{id:int}"
@model EventManager.Pages.Events.DeleteModel
@{
    ViewData["Title"] = "Удалить мероприятие";
}

<div class="container mt-4">

    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="card border-danger shadow-sm">

                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Удалить мероприятие</h4>
                </div>

                <div class="card-body">

                    <div class="alert alert-warning">
                        Вы уверены, что хотите удалить это мероприятие?
                    </div>

                    <div class="mb-3">

                        <h5 class="card-title">📅 @Model.Event.Name</h5>

                        <p class="card-text text-muted">
                            <strong>Описание:</strong> @(string.IsNullOrEmpty(Model.Event.Description) ? "Нет описания" : Model.Event.Description)
                        </p>

                        <p class="card-text">
                            <strong>Дата проведения:</strong> @Model.Event.EventDate.ToShortDateString()
                        </p>

                        <p class="card-text">
                            <strong>Место проведения:</strong> @Model.Event.location
                        </p>

                        <p class="card-text">
                            <strong>Номер мероприятия:</strong> <span class="badge bg-secondary">№ @Model.Event.EventId</span>
                        </p>

                    </div>

                    <form method="post">

                        <input type="hidden" asp-for="Event.Id" />

                        <div class="d-flex justify-content-between">

                            <a asp-page="Index" class="btn btn-secondary">
                                Отмена
                            </a>

                            <button type="submit" class="btn btn-danger">
                                Удалить
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>
    </div>

</div>