@page "{id:int}"
@model EventManager.Pages.Events.DetailsModel
@{
    ViewData["Title"] = "Информация о мероприятии";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Информация о мероприятии</h4>
                </div>
                <div class="card-body">
                    <h5 class="card-title mb-3">📅 @Model.Event.Name</h5>
                    <ul class="list-group list-group-flush mb-3">
                        <li class="list-group-item"><strong>Дата проведения:</strong> <span class="text-muted">@Model.Event.EventDate.ToShortDateString()</span></li>
                        <li class="list-group-item"><strong>Место проведения:</strong> <span class="text-muted">@Model.Event.location</span></li>
                        <li class="list-group-item"><strong>Номер мероприятия:</strong> <span class="badge bg-secondary">№ @Model.Event.Id</span></li>
                    </ul>
                    <div class="d-flex justify-content-between">
                        <a asp-page="Index" class="btn btn-secondary">Назад к списку</a>
                        <a asp-page="Edit" asp-route-id="@Model.Event.Id" class="btn btn-warning">Редактировать</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>