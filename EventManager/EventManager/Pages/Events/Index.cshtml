@page
@model EventManager.Pages.Events.IndexModel
@{
    ViewData["Title"] = "Список мероприятий";
}

<div class="container mt-4">

    <!-- Заголовок и кнопка добавления мероприятия -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Список мероприятий</h2>
        <a asp-page="Create" class="btn btn-success">
            Добавить новое мероприятие
        </a>
    </div>

    <!-- Плитки мероприятий -->
    <div class="row g-4">
        @foreach (var eventItem in Model.Events)
        {
            <!-- Каждая карточка мероприятия в колонке -->
            <div class="col-sm-6 col-md-4 col-lg-3">

                <!-- Карточка мероприятия с тенью -->
                <div class="card h-100 shadow-sm">
                    <div class="card-body">

                        <!-- Заголовок мероприятия с иконкой и обрезкой текста -->
                        <h5 class="card-title text-truncate">
                            📅 @eventItem.Name
                        </h5>

                        <!-- Дата проведения -->
                        <p class="card-text text-muted mb-1">
                            <strong>Дата:</strong> @eventItem.EventDate.ToShortDateString()
                        </p>

                        <!-- Место проведения -->
                        <p class="card-text text-muted mb-1">
                            <strong>Место:</strong> @eventItem.location
                        </p>

                        <!-- Номер мероприятия -->
                        <p class="card-text mb-2">
                            <span class="badge bg-secondary">№ @eventItem.EventId</span>
                        </p>

                        <!-- Кнопки действий -->
                        <div class="d-flex justify-content-between">
                            <a asp-page="Details" asp-route-id="@eventItem.Id" class="btn btn-sm btn-info">
                                Открыть
                            </a>
                            <a asp-page="Edit" asp-route-id="@eventItem.Id" class="btn btn-sm btn-warning">
                                Изменить
                            </a>
                            <a asp-page="Delete" asp-route-id="@eventItem.Id" class="btn btn-sm btn-danger">
                                Удалить
                            </a>
                        </div>

                    </div>
                </div>

            </div>
        }
    </div>

</div>