@page
@model EventManager.Pages.Events.IndexModel
@{
    ViewData["Title"] = "Список мероприятий";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Список мероприятий</h2>
        <a asp-page="Create" class="btn btn-success">Добавить новое мероприятие</a>
    </div>

    <div class="row g-4">
        @foreach (var eventItem in Model.Events)
        {
            <div class="col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title text-truncate">📅 @eventItem.Name</h5>
                        <p class="card-text text-muted mb-1"><strong>Дата:</strong> @eventItem.EventDate.ToShortDateString()</p>
                        <p class="card-text text-muted mb-1"><strong>Место:</strong> @eventItem.location</p>
                        <p class="card-text mb-2"><span class="badge bg-secondary">№ @eventItem.Id</span></p>
                        <div class="d-flex justify-content-between">
                            <a asp-page="Details" asp-route-id="@eventItem.Id" class="btn btn-sm btn-info">Открыть</a>
                            <a asp-page="Edit" asp-route-id="@eventItem.Id" class="btn btn-sm btn-warning">Изменить</a>
                            <a asp-page="Delete" asp-route-id="@eventItem.Id" class="btn btn-sm btn-danger">Удалить</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>